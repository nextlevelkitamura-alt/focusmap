    "type": "git",
    "url": "https://github.com/focusmap-official/focusmap-agent"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
