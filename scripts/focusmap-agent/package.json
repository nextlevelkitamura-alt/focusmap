  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "focusmap-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js start",
    "dev": "tsx src/cli.ts start"
  },
  "keywords": [
    "automation",
    "playwright",
    "focusmap",
    "saas"
  ],
  "author": "Naohiro Kitamura <hello@focusmap-official.com>",
  "license": "UNLICENSED",
  "private": false,
  "homepage": "https://focusmap-official.com",
