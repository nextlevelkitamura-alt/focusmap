{
  "name": "focusmap",
  "version": "0.1.0",
  "description": "Focusmap dashboard and Mac desktop shell",
  "author": "Focusmap",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "(sleep 3 && open http://localhost:3001 &) && NODE_OPTIONS='--max-http-header-size=65536' next dev -p 3001",
    "dev:desktop": "NODE_OPTIONS='--max-http-header-size=65536' next dev -p 3001",
    "dev:bg": "scripts/dev-session.sh start",
    "dev:restart": "scripts/dev-session.sh restart",
    "dev:status": "scripts/dev-session.sh status",
    "dev:stop": "scripts/dev-session.sh stop",
    "dev:logs": "scripts/dev-session.sh logs",
    "dev:phone": "scripts/phone-preview.sh",
    "dev:phone:auth": "node scripts/phone-preview-auth-config.mjs",
    "dev:phone:bg": "scripts/phone-preview-session.sh start",
    "dev:phone:status": "scripts/phone-preview-session.sh status",
    "dev:phone:stop": "scripts/phone-preview-session.sh stop",
    "mac:prepare-agent": "node scripts/prepare-mac-agent.mjs",
    "mac:dev": "npm run mac:prepare-agent && electron ./desktop/focusmap-mac/main.cjs",
    "mac:next-build": "next build --webpack",
    "mac:build": "node scripts/clean-mac-build.mjs && npm run mac:prepare-agent && npm run mac:next-build && node scripts/patch-next-react-loadable-manifests.mjs .next && node scripts/verify-next-static-assets.mjs .next && electron-builder --config desktop/focusmap-mac/electron-builder.yml --mac dir --arm64 && node scripts/verify-next-static-assets.mjs dist-desktop/mac-arm64/Focusmap.app/Contents/Resources/next-standalone/.next",
    "mac:install": "node scripts/install-mac-app.mjs",
    "mac:build:install": "npm run mac:build && npm run mac:install",
    "mac:dist": "node scripts/clean-mac-build.mjs && npm run mac:prepare-agent && npm run mac:next-build && node scripts/patch-next-react-loadable-manifests.mjs .next && node scripts/verify-next-static-assets.mjs .next && electron-builder --config desktop/focusmap-mac/electron-builder.yml --mac dmg --arm64 && node scripts/verify-next-static-assets.mjs dist-desktop/mac-arm64/Focusmap.app/Contents/Resources/next-standalone/.next",
    "build": "next build",
    "build:render": "NODE_OPTIONS='--max-old-space-size=512' next build",
    "start": "next start",
    "lint": "eslint",
    "setup:opencode-go": "node scripts/setup-opencode-go-env.mjs",
    "codex-monitoring:set-secrets": "node scripts/set-codex-monitoring-github-secrets.mjs",
    "codex-monitoring:migrate-turso": "node scripts/apply-turso-monitoring-migration.mjs",
    "codex-monitoring:backfill": "node scripts/backfill-codex-monitoring-to-turso.mjs",
    "deploy:cloudrun": "./deploy-cloudrun.sh",
    "security:secrets": "node scripts/check-no-secrets.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/react": "^3.0.195",
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@google/generative-ai": "^0.24.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@libsql/client": "^0.17.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@stripe/stripe-js": "^9.6.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.103",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "googleapis": "^170.1.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.3",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.8.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.53",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vercel": "^50.5.0",
    "vitest": "^4.0.18"
  }
}
