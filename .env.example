# ==========================================
# 環境変数テンプレート
# ==========================================
# このファイルをコピーして使用してください
#
# 開発環境: .env.local
# 本番環境: Renderダッシュボードで設定
# ==========================================

# ------------------------------------------
# Supabase設定
# ------------------------------------------
# Supabase プロジェクトのURL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase の匿名キー（anon key）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------
# Google Calendar API
# ------------------------------------------
# Google OAuth 2.0 クライアントID
GOOGLE_CLIENT_ID=

# Google OAuth 2.0 クライアントシークレット
GOOGLE_CLIENT_SECRET=

# Google OAuth リダイレクトURI
# 開発環境: http://localhost:3001/api/calendar/callback
# 本番環境: https://shikumika-app.onrender.com/api/calendar/callback
GOOGLE_REDIRECT_URI=

# ------------------------------------------
# NextAuth
# ------------------------------------------
# NextAuth用のベースURL
# 開発環境: http://localhost:3001
# 本番環境: https://shikumika-app.onrender.com
NEXTAUTH_URL=

# NextAuth用のシークレットキー（ランダムな文字列を生成）
# 生成方法: openssl rand -base64 32
NEXTAUTH_SECRET=

# ------------------------------------------
# AI機能（AIメモ）
# ------------------------------------------
# Gemini API キー（AI分析用）
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq API キー（音声認識用）
# 取得: https://console.groq.com/keys
GROQ_API_KEY=
