{
  "name": "focusmap-ios",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "expo": "~56.0.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:doctor": "./scripts/doctor-ios-ready.sh",
    "ios:device": "expo run:ios --device",
    "ios:device:release": "expo run:ios --device --configuration Release",
    "ios:install:free": "./scripts/install-ios-free.sh",
    "ios:morning": "./scripts/morning-install-ios.sh",
    "ios:prebuild": "expo prebuild --platform ios",
    "ios:prebuild:no-install": "expo prebuild --platform ios --no-install",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "private": true
}
